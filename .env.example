# UPgraders blog — WordPress connection (optional)
# When unset, the blog falls back to bundled local posts so the site keeps working.
#
# Provide either the full REST root or just the WP host:
#   WORDPRESS_API_URL=https://blog.upgraders.cm/wp-json/wp/v2
#   WORDPRESS_API_URL=https://blog.upgraders.cm
#
# Optional: tag/category slug to scope which posts appear in the UPgraders blog.
# WORDPRESS_FILTER_CATEGORY=upgraders
# WORDPRESS_FILTER_TAG=
#
# Optional: ISR revalidation in seconds (default 600 = 10 min).
# WORDPRESS_REVALIDATE=600
